# Offentlig base-URL til sitemap, canonicals og struktureret data (sæt til jeres primære domæne i produktion)
NEXT_PUBLIC_SITE_URL=https://vinbot.dk

# Valgfrit: komma-separerede SoMe-/profil-URL'er til Organization sameAs i JSON-LD
# NEXT_PUBLIC_ORG_SAME_AS=https://www.instagram.com/...,https://...

# Google AdSense
# CLIENT indlæser publisher-scriptet (krav for at Googlebot kan verificere jer ifm. godkendelse).
# Sæt CLIENT så snart I har en pub-ID — også før godkendelse. Scriptet er samtykke-frit.
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-7373148222153531
# ACTIVE=true aktiverer faktiske annonce-slots (AdSlot). Slå først til efter godkendelse.
# NEXT_PUBLIC_ADSENSE_ACTIVE=true

# Google Analytics 4 (Measurement ID, starter med G-)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-JB0QD6J59G

# Vercel Cron: sæt samme hemmelighed i Vercel → Environment → CRON_SECRET
CRON_SECRET=
